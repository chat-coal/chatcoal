{
  "name": "chatcoal",
  "version": "0.1.6",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "electron:dev": "concurrently -k \"vite\" \"sleep 3 && electron .\"",
    "electron:preview": "electron .",
    "electron:build": "vite build && electron-builder --config electron-builder.config.js"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "axios": "^1.13.6",
    "dbus-next": "^0.10.2",
    "electron-updater": "^6.8.3",
    "firebase": "^12.10.0",
    "livekit-client": "^2.17.2",
    "pinia": "^3.0.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.1.18",
    "uiohook-napi": "^1.5.4",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6.0.4",
    "concurrently": "^9.2.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.7"
  }
}
