export APP_DEBUG=1
export APP_DOMAIN=http://127.0.0.1:3000

export APP_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://localhost:5173

export APP_DB_USER=user
export APP_DB_PASS=pass
export APP_DB_HOST=host
export APP_DB_NAME=db

export FIREBASE_PROJECT_ID=your-firebase-project-id

export REDIS_ADDR=localhost:6379

# Snowflake node ID (0-1023). Unique per instance when running multiple backends.
export APP_SNOWFLAKE_NODE=1

# S3-compatible storage (Railway Object Storage, AWS S3, MinIO, etc.)
# Leave empty to use local ./uploads/ directory
export S3_ENDPOINT=
export S3_ACCESS_KEY=
export S3_SECRET_KEY=
export S3_BUCKET=
export S3_USE_SSL=true

# LiveKit (voice channels)
export LIVEKIT_URL=http://localhost:7880
export LIVEKIT_API_KEY=devkey
export LIVEKIT_API_SECRET=secret

# Metrics (optional — protects /internal/metrics endpoint)
export METRICS_TOKEN=

# Federation (optional — enables cross-instance login)
# Set FEDERATION_DOMAIN to the public hostname of this instance.
export APP_NAME=chatcoal
export FEDERATION_DOMAIN=

# Site admin UIDs (comma-separated Firebase UIDs that can access /api/admin endpoints)
export SITE_ADMIN_UIDS=
