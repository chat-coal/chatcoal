# ─── Traefik / Let's Encrypt ──────────────────────────────────────────────────
ACME_EMAIL=you@example.com

# ─── Database ─────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
DB_NAME=chatcoal
DB_USER=chatcoal
DB_PASS=chatcoal

# ─── Backend ──────────────────────────────────────────────────────────────────
APP_DEBUG=0
APP_SNOWFLAKE_NODE=1
APP_NAME=chatcoal

# ─── Federation (optional — enables cross-instance login) ─────────────────────
# Set to the public hostname of this instance (e.g. chat.example.com).
FEDERATION_DOMAIN=

# Site admin UIDs (comma-separated Firebase UIDs that can access /api/admin endpoints)
SITE_ADMIN_UIDS=

# ─── Metrics ─────────────────────────────────────────────────────────────────
# Shared secret for /internal/metrics endpoint (used by backend + monitoring)
METRICS_TOKEN=

# ─── Firebase (server-side) ───────────────────────────────────────────────────
# Place your firebase-service-account.json in backend/
FIREBASE_PROJECT_ID=your-project-id

# ─── S3-compatible Storage (optional) ─────────────────────────────────────────
# Leave empty to use local ./uploads/ volume
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_USE_SSL=false

# ─── LiveKit (voice channels) ─────────────────────────────────────────────────
# If you change these, also update livekit.yaml to match
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ─── Firebase (client-side) ───────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ─── LiveKit (client-side) ────────────────────────────────────────────────────
# Change to match your domain (must match Traefik host rule in docker-compose.yml)
VITE_LIVEKIT_URL=wss://livekit.chatcoal.com
